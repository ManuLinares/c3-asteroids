{
	"langrev": "1",
	"warnings": [ "no-unused" ],
	"dependency-search-paths": [],
	"dependencies": [],
	"authors": [ "Manuel Linares <mbarriolinares@gmail.com>" ],
	"version": "0.1.0",
	"sources": [ "src/**", "lib/rgfw.c3", "lib/miniaudio.c3" ],
	"c-include-dirs": [ "deps/miniaudio" ],
	"test-sources": [ "test/**" ],
	"build-dir": "build",
	"output": "build",
	"script-dir": ".",
	"targets": {
		"linux": {
			"type": "executable",
			"name": "asteroids",
			"linked-libraries": [
				"deps/RGFW_linux_amd64/lib/libRGFW.a",
				"deps/miniaudio_linux_amd64/lib/libminiaudio.a",
				"X11", "Xrandr", "wayland-client", "wayland-cursor", "wayland-egl", "xkbcommon",
				"m", "dl", "rt", "pthread"
			],
			"exec": [
				"scripts/build_rgfw_linux.sh",
				"scripts/build_miniaudio.sh linux"
			]
		},
		"windows": {
			"type": "executable",
			"name": "asteroids",
			"target": "windows-x64",
			"link-args": [ "deps/RGFW_windows_amd64/lib/RGFW.lib", "deps/miniaudio_windows_amd64/lib/miniaudio.obj" ],
			"linked-libraries": [ "gdi32", "shell32", "user32", "winmm" ],
			"exec": [
				"scripts/build_miniaudio.sh windows"
			]
		},
		"web": {
			"type": "prepare",
			"exec": [
				"scripts/build_rgfw_wasm.sh",
				"scripts/build_miniaudio.sh wasm",
				"scripts/build_web.sh" ]
		},

		"list_objs": {
			"type": "object-files"
		},
		"web_objs": {
			"type": "object-files",
			"target": "wasm32",
			"link-libc": true,
			"cc": "emcc"
		}
	},
	"cpu": "generic",
	"opt": "O1",
	"debug-info": "none"
}